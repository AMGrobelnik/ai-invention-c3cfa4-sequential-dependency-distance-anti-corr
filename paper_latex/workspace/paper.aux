\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Phase 4--5: Typological Modulation}{12}{subsection.4.3}\protected@file@percent }
\newlabel{sec:typological}{{4.3}{12}{Phase 4--5: Typological Modulation}{subsection.4.3}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.3.1}Case-Marking Richness}{12}{subsubsection.4.3.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Relationship between morphological case-marking richness (WALS Chapter 49A ordinal scale) and mean excess-RPL autocorrelation across treebanks. Languages with richer case systems show less negative (weaker) compensatory anti-correlation ($\beta = 0.080$, $p < 10^{-6}$ in mixed-effects model with language-family random intercepts). Each point represents one treebank; color indicates modality (blue = written, red = spoken). Dashed line shows the OLS regression fit.}}{12}{figure.5}\protected@file@percent }
\newlabel{fig:case_marking}{{5}{12}{Relationship between morphological case-marking richness (WALS Chapter 49A ordinal scale) and mean excess-RPL autocorrelation across treebanks. Languages with richer case systems show less negative (weaker) compensatory anti-correlation ($\beta = 0.080$, $p < 10^{-6}$ in mixed-effects model with language-family random intercepts). Each point represents one treebank; color indicates modality (blue = written, red = spoken). Dashed line shows the OLS regression fit}{figure.5}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.3.2}Spoken vs.\ Written Modality}{13}{subsubsection.4.3.2}\protected@file@percent }
