\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.1.1}Monte Carlo Estimator Comparison}{8}{subsubsection.4.1.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Left: Power curves for the standard $r_1$ estimator at sequence lengths $n \in \{10, 15, 20\}$ across true autocorrelation values $\rho \in [-0.40, 0.40]$, showing that no individual sequence achieves 80\% power. Right: Geometric confound analysis on canonical tree types ($n = 20$, 500 trees each). Star, caterpillar, and balanced trees produce zero or positive excess-RPL; only random projective trees produce negative excess ($-0.125$), but RPL-vs-RPL control confirms this excess is zero under the null ($+0.001$, $p = 0.23$).}}{8}{figure.2}\protected@file@percent }
\newlabel{fig:monte_carlo}{{2}{8}{Left: Power curves for the standard $r_1$ estimator at sequence lengths $n \in \{10, 15, 20\}$ across true autocorrelation values $\rho \in [-0.40, 0.40]$, showing that no individual sequence achieves 80\% power. Right: Geometric confound analysis on canonical tree types ($n = 20$, 500 trees each). Star, caterpillar, and balanced trees produce zero or positive excess-RPL; only random projective trees produce negative excess ($-0.125$), but RPL-vs-RPL control confirms this excess is zero under the null ($+0.001$, $p = 0.23$)}{figure.2}{}}
\citation{Nivre2020}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.1.2}Geometric Confound Analysis}{9}{subsubsection.4.1.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Phase 2--3: Excess Autocorrelation Across 233 Treebanks}{9}{subsection.4.2}\protected@file@percent }
\newlabel{sec:main_meta}{{4.2}{9}{Phase 2--3: Excess Autocorrelation Across 233 Treebanks}{subsection.4.2}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.2.1}Main Meta-Analytic Results}{9}{subsubsection.4.2.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Random-effects meta-analytic pooled estimates of excess autocorrelation across 233 treebanks. All estimates are significantly negative ($p < 10^{-170}$). The hierarchy shows monotonic attenuation as baselines incorporate more grammatical structure.}}{9}{table.1}\protected@file@percent }
\newlabel{tab:main_results}{{1}{9}{Random-effects meta-analytic pooled estimates of excess autocorrelation across 233 treebanks. All estimates are significantly negative ($p < 10^{-170}$). The hierarchy shows monotonic attenuation as baselines incorporate more grammatical structure}{table.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Histogram of per-treebank mean excess-RPL autocorrelation across 233 qualifying treebanks from Universal Dependencies v2.17. The pooled random-effects meta-analytic estimate is $-0.131$ (vertical dashed red line). 99.1\% of treebanks (231/233) show negative excess. The distribution spans from approximately $-0.30$ to $+0.02$, with median $-0.143$.}}{10}{figure.3}\protected@file@percent }
\newlabel{fig:histogram}{{3}{10}{Histogram of per-treebank mean excess-RPL autocorrelation across 233 qualifying treebanks from Universal Dependencies v2.17. The pooled random-effects meta-analytic estimate is $-0.131$ (vertical dashed red line). 99.1\% of treebanks (231/233) show negative excess. The distribution spans from approximately $-0.30$ to $+0.02$, with median $-0.143$}{figure.3}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.2.2}Within-Treebank Pervasiveness}{10}{subsubsection.4.2.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.2.3}Language-Level Sensitivity}{11}{subsubsection.4.2.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Pooled meta-analytic estimates of excess autocorrelation at three baseline tiers across 233 treebanks. The effect attenuates monotonically from excess-RPL ($-0.131$) through excess-FHD ($-0.084$) to excess-SOP ($-0.071$) as baselines incorporate more grammatical structure, but remains highly significant at all tiers. Error bars show 95\% confidence intervals; shaded bands show 95\% prediction intervals.}}{11}{figure.4}\protected@file@percent }
\newlabel{fig:attenuation}{{4}{11}{Pooled meta-analytic estimates of excess autocorrelation at three baseline tiers across 233 treebanks. The effect attenuates monotonically from excess-RPL ($-0.131$) through excess-FHD ($-0.084$) to excess-SOP ($-0.071$) as baselines incorporate more grammatical structure, but remains highly significant at all tiers. Error bars show 95\% confidence intervals; shaded bands show 95\% prediction intervals}{figure.4}{}}
\citation{Bentz2017}
